{
  "name": "wellminds-backend-v2",
  "version": "2.1.0",
  "description": "WellMinds v2 — additive module on top of v1. Adds RBAC, pulse, indicator ranges, connect cycles, growth leaderboards, EAP, comm templates, and social-wall audience targeting.",
  "main": "src/index-v2.js",
  "scripts": {
    "start": "node src/index-v2.js",
    "dev": "nodemon src/index-v2.js",
    "db:migrate-v2": "node -e \"require('fs');const pg=require('pg');require('dotenv').config({path:'../well-minds/.env'});const sql=require('fs').readFileSync('./schema/schema-v2.sql','utf8');const c=new pg.Client({connectionString:process.env.DATABASE_URL});c.connect().then(()=>c.query(sql)).then(()=>{console.log('[migrate-v2] ok');c.end();}).catch(e=>{console.error(e);process.exit(1);});\"",
    "db:seed-v2": "node scripts/seed-v2.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
